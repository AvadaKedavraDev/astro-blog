---
import BaseLayout from "@layouts/BaseLayout.astro";
import BookMarkManager from "@components/ui/BookMarkManager.astro"

const categories = [
    {
        title: "常用工具",
        icon: "🧰",
        links: [
            {name: "Gemini", url: "https://gemini.google.com/app", desc: "AI 助手"},
            {name: "Kimi", url: "https://www.kimi.com/", desc: "Kimi"},
            {name: "元宝", url: "https://yuanbao.tencent.com/", desc: "腾讯元宝"},
            {name: "乐此证书", url: "https://console.letsencrypt.top/", desc: "免费证书"},
            {name: "GitHub", url: "https://github.com", desc: "代码托管与协作"},
            {name: "BeJson", url: "https://www.bejson.com", desc: "JSON 格式化"},
            {name: "Excalidraw", url: "https://excalidraw.com/", desc: "手绘风格"},
        ]
    },
    {
        title: "Code",
        icon: "💻",
        links: [
            {name: "OpenCode", url: "https://opencode.ai", desc: "AI 编程助手"},
            {name: "Kimi Code", url: "https://kimi.moonshot.cn/", desc: "Kimi 编程助手"},
            {name: "Claude Code", url: "https://claude.com/claude-code", desc: "Anthropic CLI 工具"},
        ]
    },
    {
        title: "开发资源",
        icon: "🛠️",
        links: [
            {name: "Tailwind CSS", url: "https://tailwindcss.com", desc: "原子化 CSS 框架"},
            {name: "Astro Docs", url: "https://docs.astro.build", desc: "Astro 官方文档"},
            {name: "MDN Web Docs", url: "https://developer.mozilla.org", desc: "Web 技术文档"},
        ]
    },
    {
        title: "学习资源",
        icon: "🎓",
        links: [
            {name: "Hello 算法", url: "https://www.hello-algo.com", desc: "算法学习入门"},
        ]
    } 
]
---

<BaseLayout title="工具箱" description="精选的开发工具与资源">
    <div class="pt-32 pb-24 px-6">
        <div class="container-wide">
            <!-- Header -->
            <header class="mb-16 text-center">
                <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
                    工具箱
                </h1>
                <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
                    精选的常用工具与开发资源，提升工作效率
                </p>
            </header>

            <!-- BookMark Manager -->
            <BookMarkManager {categories}/>
        </div>
    </div>
</BaseLayout>
