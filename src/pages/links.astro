---
import BaseLayout from "@layouts/BaseLayout.astro";
import BookMarkManager from "@components/ui/BookMarkManager.astro"

const categories = [
    {
        title: "常用工具",
        icon: "🧰",
        links: [
            {name: "Google", url: "https://www.google.com", desc: "搜索引擎"},
            {name: "Gemini", url: "https://gemini.google.com/app", desc: "Google AI 助手"},
            {name: "Kimi", url: "https://www.kimi.com/", desc: "Moonshot 长文本助手"},
            {name: "BeJson", url: "https://www.bejson.com", desc: "JSON 格式化校验"},
            {name: "程序员论坛", url: "https://www.v2ex.com/", desc: "v2程序员栈"},
        ]
    },
    {
        title: "AI 助手",
        icon: "🤖",
        links: [
            {name: "Gemini", url: "https://gemini.google.com/app", desc: "Google AI 助手"},
            {name: "Kimi", url: "https://www.kimi.com/", desc: "Moonshot 长文本助手"},
            {name: "腾讯元宝", url: "https://yuanbao.tencent.com/", desc: "腾讯混元大模型"},
            {name: "OpenCode", url: "https://opencode.ai", desc: "AI 编程助手"},
            {name: "Claude Code", url: "https://claude.com/claude-code", desc: "Anthropic CLI 工具"},
        ]
    },
    {
        title: "AI 技术栈",
        icon: "⚡",
        links: [
            {name: "Hugging Face", url: "https://huggingface.co", desc: "AI 模型与数据集社区"},
            {name: "Ollama", url: "https://ollama.com", desc: "本地运行大语言模型"},
            {name: "魔搭 ModelScope", url: "https://modelscope.cn", desc: "阿里 AI 模型平台"},
            {name: "Spring AI", url: "https://spring.io/projects/spring-ai", desc: "Spring AI 框架"},
            {name: "LangChain", url: "https://www.langchain.com", desc: "LLM 应用开发框架"},
            {name: "LangChain4j", url: "https://docs.langchain4j.dev", desc: "Java 版 LangChain"},
            {name: "LlamaIndex", url: "https://www.llamaindex.ai", desc: "RAG 应用开发框架"},
            {name: "Jina AI", url: "https://jina.ai", desc: "嵌入模型与神经搜索"},
            {name: "vLLM", url: "https://docs.vllm.ai", desc: "大模型推理加速引擎"},
            {name: "OpenRouter", url: "https://openrouter.ai", desc: "统一 AI API 网关"},
        ]
    },
    {
        title: "数据与向量",
        icon: "🗃️",
        links: [
            {name: "Apache Tika", url: "https://tika.apache.org", desc: "文档内容提取工具"},
            {name: "MTEB Leaderboard", url: "https://huggingface.co/spaces/mteb/leaderboard", desc: "文本嵌入模型排行榜"},
            {name: "ChromaDB", url: "https://www.trychroma.com", desc: "开源向量数据库"},
            {name: "Milvus", url: "https://milvus.io", desc: "云原生向量数据库"},
            {name: "Pinecone", url: "https://www.pinecone.io", desc: "托管向量数据库"},
        ]
    },
    {
        title: "开发工具",
        icon: "🛠️",
        links: [
            {name: "GitHub", url: "https://github.com", desc: "代码托管与协作"},
            {name: "BeJson", url: "https://www.bejson.com", desc: "JSON 格式化校验"},
            {name: "Excalidraw", url: "https://excalidraw.com/", desc: "手绘风格白板"},
            {name: "Tailwind CSS", url: "https://tailwindcss.com", desc: "原子化 CSS 框架"},
            {name: "Astro Docs", url: "https://docs.astro.build", desc: "Astro 官方文档"},
            {name: "MDN Web Docs", url: "https://developer.mozilla.org", desc: "Web 技术权威文档"},
            {name: "乐此证书", url: "https://console.letsencrypt.top/", desc: "免费 SSL 证书"},
        ]
    },
    {
        title: "学习资源",
        icon: "📚",
        links: [
            {name: "Hello 算法", url: "https://www.hello-algo.com", desc: "算法学习入门经典"},
        ]
    }
]
---

<BaseLayout title="工具箱" description="精选的开发工具与资源">
    <div class="pt-32 pb-24 px-6">
        <div class="container-wide">
            <!-- Header -->
            <header class="mb-16 text-center">
                <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
                    工具箱
                </h1>
                <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
                    精选的常用工具与开发资源，提升工作效率
                </p>
            </header>

            <!-- BookMark Manager -->
            <BookMarkManager {categories}/>
        </div>
    </div>
</BaseLayout>
