---
/**
 * @layout BaseLayout
 * @description 基础布局组件，提供站点通用的页面结构
 * @features SEO、导航栏、页脚、View Transitions、主题切换、返回顶部、开屏弹窗
 * @props title - 页面标题
 * @props description - 页面描述（可选）
 * @props canonicalUrl - 规范链接（可选）
 * @props ogImage - OG 图片（可选）
 */
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

import SEO from "@components/widgets/SEO.astro";
import Navigation from "@components/common/Navigation.astro";
import Footer from "@components/common/Footer.astro";
import ScrollToTop from "@components/ui/ScrollToTop.astro";

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  disableMainTransition?: boolean;
}

const {
  title,
  description = "一个极简现代的个人博客",
  canonicalUrl = Astro.url.href,
  ogImage,
  disableMainTransition = false,
} = Astro.props;

const fullTitle = title === "首页" ? "Moonpeak" : `${title} — Moonpeak`;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth antialiased">
  <head>
    <SEO title={fullTitle} {description} {canonicalUrl} {ogImage} />
    <ClientRouter />
    
    {/* 首页预加载关键资源 */}
    {title === "首页" && (
      <link rel="preload" href="/logo.png" as="image" type="image/png" fetchpriority="high" />
    )}
    <meta name="baidu-site-verification" content="codeva-DaleZ0kdGN" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 网站图标：使用 logo.png -->
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" href="/logo.png" />

    {/* 使用本地字体文件，不依赖外部 CDN */}
    <link rel="stylesheet" href="/fonts/fonts.css">

    {/* ===== KaTeX 数学公式样式 ===== */}
    <link rel="stylesheet" href="/katex.min.css">

    {/* 关键 CSS - 防止闪烁 */}
    <style is:inline>:root { color-scheme: light dark; } :root.dark { color-scheme: dark; }</style>
    
    {/* 主题初始化 - 同步执行防止闪烁 */}
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

          if (theme === 'dark') {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
          
          document.documentElement.dataset.themeInitialized = 'true';
        }
        
        applyTheme();
        
        document.addEventListener('astro:before-swap', (event) => {
          const theme = localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          
          if (theme === 'dark') {
            event.newDocument.documentElement.classList.add('dark');
          } else {
            event.newDocument.documentElement.classList.remove('dark');
          }
        });
      })();
    </script>

    <script is:inline>
      (function() {
        function disableSmoothScroll() {
          document.documentElement.style.scrollBehavior = 'auto';
          document.body.style.scrollBehavior = 'auto';
        }

        function restoreSmoothScroll() {
          document.documentElement.style.removeProperty('scroll-behavior');
          document.body.style.removeProperty('scroll-behavior');
        }

        document.addEventListener('astro:before-preparation', disableSmoothScroll);
        document.addEventListener('astro:before-swap', disableSmoothScroll);
        document.addEventListener('astro:page-load', restoreSmoothScroll);
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background text-foreground">
    <div class="contents">
      <Navigation />
    </div>

    <main class="pt-16" transition:animate={disableMainTransition ? undefined : "fade"}>
      <slot />
    </main>

    <div>
      <Footer />
    </div>
    <ScrollToTop />

    <slot name="footer-scripts" />

    {/* rehype-code-group 代码块多标签切换初始化 */}
    <script is:inline src="/js/code-groups.js"></script>
  </body>
</html>
