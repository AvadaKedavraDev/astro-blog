---
/**
 * @component SwupCompat
 * @description Swup 兼容性工具组件，提供统一的生命周期事件管理
 * @features onPageView、beforeContentReplace API、动画偏好检测、ARIA 支持
 * @props propName - 属性说明
 * @usage 在 BaseLayout 中引用，其他组件通过 window.SwupCompat 访问
 */
---

<script is:inline>
// @ts-nocheck - 这是一个纯 JavaScript 文件，禁用 TypeScript 检查
(function() {
  'use strict';
  
  // 如果已经存在且已就绪，直接返回
  if (window.SwupCompat && window.SwupCompat.__isReady__) {
    return;
  }
  
  // 检测用户动画偏好
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  // 保留已有的回调（如果存在）
  const existingCallbacks = window.SwupCompat?.callbacks || {
    'page:view': [],
    'content:replace:before': []
  };
  
  // 创建全局 Swup 兼容管理器
  window.SwupCompat = {
    // 回调注册表（保留已有的）
    callbacks: {
      'page:view': [...existingCallbacks['page:view']],
      'content:replace:before': [...existingCallbacks['content:replace:before']]
    },
    
    // 动画偏好
    prefersReducedMotion,
    
    // 是否已初始化事件监听
    __isReady__: false,
    
    // 注册页面视图回调（页面切换完成后）
    onPageView(callback, options = {}) {
      const { immediate = true, respectMotionPreference = true } = options;
      
      // 如果用户偏好减少动画且选项启用，跳过动画相关的回调
      const wrappedCallback = respectMotionPreference && this.prefersReducedMotion
        ? () => { callback(); }
        : callback;
      
      // 添加到注册表
      this.callbacks['page:view'].push(wrappedCallback);
      
      // 立即执行一次（如果页面已加载）
      if (immediate && document.readyState !== 'loading') {
        try {
          wrappedCallback();
        } catch (e) {
          console.error('SwupCompat: 初始回调执行失败:', e);
        }
      }
      
      return () => this.off('page:view', wrappedCallback);
    },
    
    // 注册内容替换前回调
    beforeContentReplace(callback) {
      this.callbacks['content:replace:before'].push(callback);
      return () => this.off('content:replace:before', callback);
    },
    
    // 移除回调
    off(event, callback) {
      if (this.callbacks[event]) {
        const index = this.callbacks[event].indexOf(callback);
        if (index > -1) {
          this.callbacks[event].splice(index, 1);
        }
      }
    },
    
    // 触发回调
    emit(event) {
      if (this.callbacks[event]) {
        this.callbacks[event].forEach(callback => {
          try {
            callback();
          } catch (e) {
            console.error(`SwupCompat: ${event} 回调执行失败:`, e);
          }
        });
      }
    },
    
    // 手动触发 Swup Scripts Plugin
    runScripts() {
      const scriptsPlugin = window.swup?.findPlugin('SwupScriptsPlugin');
      if (scriptsPlugin && scriptsPlugin.runScripts) {
        // 使用 call 绑定 this，确保方法内部能正确访问 this.options 和 this.swup
        scriptsPlugin.runScripts.call(scriptsPlugin);
      }
    },
    
    // 配置 Scroll Plugin（官方推荐方式）
    configureScrollPlugin(options = {}) {
      const scrollPlugin = window.swup?.findPlugin('SwupScrollPlugin');
      if (!scrollPlugin) return false;
      
      // 应用配置
      if (options.offset !== undefined) {
        scrollPlugin.options.offset = options.offset;
      }
      if (options.animateScroll !== undefined) {
        scrollPlugin.options.animateScroll = options.animateScroll;
      }
      if (options.doScrollingRightAway !== undefined) {
        scrollPlugin.options.doScrollingRightAway = options.doScrollingRightAway;
      }
      
      return true;
    },
    
    // 清理动态添加的内容（在 Swup 导航前调用）
    cleanup() {
      // 清理 rehype-code-group 的初始化标记
      document.querySelectorAll('.rehype-code-group[data-swup-compat-initialized]').forEach((group) => {
        delete group.dataset.swupCompatInitialized;
      });
      
      // 清理动态添加的微交互标记
      document.querySelectorAll('[data-magnetic-init]').forEach((el) => {
        delete el.dataset.magneticInit;
      });
      document.querySelectorAll('[data-card3d-init]').forEach((el) => {
        delete el.dataset.card3dInit;
      });
      document.querySelectorAll('[data-ripple-init]').forEach((el) => {
        delete el.dataset.rippleInit;
      });
    },
    
    // 初始化 rehype-code-group 代码块多标签切换
    initCodeGroups() {
      const codeGroups = document.querySelectorAll('.rehype-code-group');
      if (codeGroups.length === 0) return;
      
      codeGroups.forEach((group) => {
        // 跳过已初始化的组（防止重复绑定）
        if (group.dataset.swupCompatInitialized) return;
        
        const tabs = group.querySelectorAll('.rcg-tab');
        const blocks = group.querySelectorAll('.rcg-block');
        
        if (tabs.length === 0 || blocks.length === 0) return;
        
        // 标记为已初始化
        group.dataset.swupCompatInitialized = 'true';
        
        // 获取当前激活状态
        let activeTab = group.querySelector('.rcg-tab.active');
        let activeBlock = group.querySelector('.rcg-block.active');
        
        // 添加点击事件监听
        group.addEventListener('click', (event) => {
          const tab = event.target.closest('.rcg-tab');
          if (!tab) return;
          
          const index = Array.from(tabs).indexOf(tab);
          if (index === -1) return;
          
          // 移除当前激活状态
          if (activeTab) {
            activeTab.classList.remove('active');
            activeTab.setAttribute('aria-selected', 'false');
          }
          if (activeBlock) {
            activeBlock.classList.remove('active');
            activeBlock.setAttribute('hidden', 'true');
          }
          
          // 激活新标签
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');
          
          const newBlock = blocks[index];
          if (newBlock) {
            newBlock.classList.add('active');
            newBlock.removeAttribute('hidden');
          }
          
          // 更新激活状态引用
          activeTab = tab;
          activeBlock = newBlock;
        });
      });
      
      if (codeGroups.length > 0) {
        console.log('[SwupCompat] Initialized rehype-code-group:', codeGroups.length, 'groups');
      }
    },
    
    // 更新 ARIA live 区域（用于屏幕阅读器）
    updateA11yNotification(message) {
      const liveRegion = document.getElementById('swup-aria-live');
      if (liveRegion) {
        liveRegion.textContent = message;
        // 3秒后清空，避免重复读取
        setTimeout(() => {
          if (liveRegion.textContent === message) {
            liveRegion.textContent = '';
          }
        }, 3000);
      }
    },
    
    // 初始化事件监听
    init() {
      if (this.__isReady__) return;
      
      // 标记是否使用新版 hooks，避免重复触发
      let usingNewHooks = false;
      
      // 监听 Swup 标准事件（旧版兼容）- 仅当新版 hooks 不可用时使用
      document.addEventListener('swup:contentReplaced', () => {
        if (usingNewHooks) return; // 如果已使用新版 hooks，跳过旧版事件
        this.runScripts(); // 手动触发脚本执行
        this.initCodeGroups(); // 初始化 rehype-code-group
        requestAnimationFrame(() => {
          setTimeout(() => {
            this.emit('page:view');
            this.updateA11yNotification('页面已加载');
          }, 0);
        });
      });
      
      document.addEventListener('swup:beforeContentReplace', () => {
        if (usingNewHooks) return;
        this.emit('content:replace:before');
        this.cleanup(); // 清理动态内容
        this.updateA11yNotification('正在加载页面...');
      });
      
      // 监听 Swup hooks（新版）
      const bindSwupHooks = () => {
        if (window.swup?.hooks) {
          console.log('[SwupCompat] Binding to swup hooks');
          usingNewHooks = true; // 标记使用新版 hooks
          
          // 配置 Scroll Plugin - 尽早配置，确保在滚动发生前生效
          // 禁用 Swup 的平滑滚动动画，由 CSS scroll-behavior: smooth 控制，避免冲突
          this.configureScrollPlugin({
            offset: 96, // 导航栏高度 64px + 额外间距 32px
            animateScroll: false, // 禁用 Swup 的动画，避免与 CSS 冲突
            doScrollingRightAway: false // 在内容替换后滚动
          });
          
          // 注意：Swup 4.x 的 hooks 命名
          // 'content:replace' 在内容替换前触发（对应旧版的 beforeContentReplace）
          // 'page:view' 在页面视图更新后触发（对应旧版的 contentReplaced）
          window.swup.hooks.on('content:replace', () => {
            this.emit('content:replace:before');
            this.cleanup(); // 清理动态内容
            this.updateA11yNotification('正在加载页面...');
          });
          
          // page:view 在内容替换完成后触发
          window.swup.hooks.on('page:view', () => {
            this.runScripts(); // 手动触发脚本执行
            this.initCodeGroups(); // 初始化 rehype-code-group
            // 延迟触发 page:view，确保 DOM 已更新
            requestAnimationFrame(() => {
              this.emit('page:view');
              this.updateA11yNotification('页面已加载');
            });
          });
          
          return true;
        }
        return false;
      };
      
      if (!bindSwupHooks()) {
        document.addEventListener('swup:enable', () => {
          bindSwupHooks();
        }, { once: true });
      }
      
      document.addEventListener('astro:page-load', () => {
        this.emit('page:view');
        this.initCodeGroups(); // 初始化 rehype-code-group
      });
      
      // 初始页面加载时也执行
      if (document.readyState !== 'loading') {
        this.initCodeGroups();
      } else {
        document.addEventListener('DOMContentLoaded', () => this.initCodeGroups());
      }
      
      // 监听动画偏好变化
      const motionMediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (motionMediaQuery.addEventListener) {
        motionMediaQuery.addEventListener('change', (e) => {
          this.prefersReducedMotion = e.matches;
          // 重新配置 Scroll Plugin - 保持 animateScroll: false，由 CSS 控制
          this.configureScrollPlugin({
            animateScroll: false
          });
        });
      }
      
      this.__isReady__ = true;
    }
  };
  
  // 立即初始化
  window.SwupCompat.init();
})();
</script>

<!-- ARIA live 区域，用于屏幕阅读器通知页面变化 -->
<div 
  id="swup-aria-live" 
  aria-live="polite" 
  aria-atomic="true" 
  class="sr-only"
  style="position: absolute; left: -10000px; width: 1px; height: 1px; overflow: hidden;"
>
</div>
