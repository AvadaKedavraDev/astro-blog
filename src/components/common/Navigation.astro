---
/**
 * @component Navigation
 * @description 顶部导航栏组件，支持桌面端和移动端响应式布局
 * @features 当前页高亮、移动端菜单、主题切换、View Transitions 兼容、Command Palette
 * @usage 在 BaseLayout 中引用
 */
import ThemeIcon from "@components/widgets/ThemeIcon.astro";
import CommandPalette from "@components/ui/CommandPalette.astro";
import { Icon } from "astro-icon/components";
import Image from "../ui/Image.astro";

interface NavItem {
  label: string;
  href: string;
  icon: string;
  children?: NavItem[];
}

const navItems: NavItem[] = [
  { label: '首页', href: '/', icon: 'lucide:home' },
  { label: '文章', href: '/blog', icon: 'lucide:file-text' },
  { label: '关于', href: '/about', icon: 'lucide:user' },
  { 
    label: '工具', 
    href: '/tools', 
    icon: 'lucide:folder',
    children: [
      { label: '工具箱', href: '/links', icon: 'lucide:box' },
      { label: '图示', href: '/visualizer', icon: 'lucide:git-graph' },
      { label: '远程', href: '/remote', icon: 'lucide:monitor' }
    ]
  }
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 pointer-events-auto" id="main-nav" data-current-path={currentPath}>
  <!-- 背景层 - 动态切换 -->
  <div class="nav-bg absolute inset-0 transition-all duration-500 pointer-events-none"
       style="opacity: 0; background-color: transparent; backdrop-filter: blur(24px);"></div>
  
  <nav class="container-wide h-16 flex items-center justify-between relative z-10">
    <!-- Logo -->
    <a href="/" class="text-lg font-semibold tracking-tight hover:opacity-70 transition-opacity flex items-center gap-2 group">
      <Image src="/logo.png" alt="Moonpeak logo" class="h-9 w-auto" />
      <span>Moonpeak</span>
    </a>
    
    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1" id="desktop-nav">
      {navItems.map((item) => (
        item.children ? (
          <div class="relative group -my-2" data-dropdown>
            <button
              class="nav-link relative px-4 py-2 text-sm rounded-lg border border-transparent nav-link-interactive flex items-center gap-2 group cursor-pointer"
              data-dropdown-trigger
            >
              <Icon name={item.icon} class="w-4 h-4 transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-0.5" />
              <span>{item.label}</span>
              <Icon name="lucide:chevron-down" class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" />
            </button>
            <div data-dropdown-menu class="dropdown-menu absolute top-full left-0 mt-0 pt-1 w-40 rounded-lg bg-card border border-border shadow-lg opacity-0 invisible transform -translate-y-2 transition-all duration-200">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  data-nav-item
                  data-href={child.href}
                  class="nav-link block px-4 py-2 text-sm rounded-lg border border-transparent nav-link-interactive"
                >
                  <div class="flex items-center gap-2">
                    <Icon name={child.icon} class="w-4 h-4" />
                    <span>{child.label}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            data-nav-item
            data-href={item.href}
            class="nav-link relative px-4 py-2 text-sm rounded-lg border border-transparent nav-link-interactive flex items-center gap-2 group"
          >
            <Icon name={item.icon} class="w-4 h-4 transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-0.5" />
            <span>{item.label}</span>
            <span class="nav-active-bar absolute inset-x-3 -bottom-0.5 h-0.5 rounded-full opacity-0"></span>
          </a>
        )
      ))}
      <div class="pl-3 ml-2 border-l border-border flex items-center gap-2">
        <!-- Command Palette Trigger -->
        <CommandPalette />
        <ThemeIcon size="sm" variant="icon" />
      </div>
    </div>
    
    <!-- Mobile Menu Button -->
    <div class="flex items-center gap-3 md:hidden">
      <!-- Mobile Command Palette Trigger -->
      <button
        id="mobile-cmd-trigger"
        class="p-2 text-muted-foreground hover:text-foreground transition-colors"
        aria-label="搜索"
      >
        <Icon name="lucide:search" class="w-5 h-5" />
      </button>
      <ThemeIcon size="sm" variant="icon" />
      <button
        id="mobile-menu-btn"
        class="p-2 -mr-2 text-muted-foreground hover:text-foreground transition-colors"
        aria-label="菜单"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" id="menu-icon" class="w-5 h-5" />
        <Icon name="lucide:x" id="close-icon" class="w-5 h-5 hidden" />
      </button>
    </div>
  </nav>
  
  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border/80 bg-background/95 backdrop-blur-sm"
  >
    <div class="container-wide py-3 space-y-1" id="mobile-nav-items">
      <!-- Search in mobile menu -->
      <a
        href="/search"
        data-mobile-nav-item
        data-href="/search"
        class="mobile-nav-link block px-4 py-3 rounded-lg border border-transparent text-base nav-link-interactive"
      >
        <div class="flex items-center gap-3">
          <Icon name="lucide:search" class="w-5 h-5" data-icon />
          <span class="nav-label">搜索</span>
        </div>
      </a>
      {navItems.map((item) => (
        item.children ? (
          <div class="mobile-nav-group">
            <div class="flex items-center gap-3 px-4 py-3 text-base text-muted-foreground">
              <Icon name={item.icon} class="w-5 h-5" />
              <span>{item.label}</span>
            </div>
            <div class="ml-6 border-l border-border pl-4 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  data-mobile-nav-item
                  data-href={child.href}
                  class="mobile-nav-link block px-4 py-3 rounded-lg border border-transparent text-base nav-link-interactive"
                >
                  <div class="flex items-center gap-3">
              <Icon name={child.icon} class="w-5 h-5" data-icon />
                    <span class="nav-label">{child.label}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            data-mobile-nav-item
            data-href={item.href}
            class="mobile-nav-link block px-4 py-3 rounded-lg border border-transparent text-base nav-link-interactive"
          >
            <div class="flex items-center gap-3">
              <Icon name={item.icon} class="w-5 h-5" data-icon />
              <span class="nav-label">{item.label}</span>
            </div>
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script is:inline>
  // @ts-nocheck - 这是一个纯 JavaScript 文件，禁用 TypeScript 检查
  (function() {
    // 判断是否是当前页面
    function isActive(itemHref, currentPath) {
      if (itemHref === '/') {
        return currentPath === '/';
      }
      return currentPath === itemHref || currentPath.startsWith(itemHref + '/');
    }
    
    // 更新导航高亮状态
    function updateNavHighlight() {
      const currentPath = window.location.pathname;
      
      // 更新桌面导航
      document.querySelectorAll('[data-nav-item]').forEach(link => {
        const href = link.getAttribute('data-href');
        if (isActive(href, currentPath)) {
          link.classList.add('nav-link-active');
        } else {
          link.classList.remove('nav-link-active');
        }
      });
      
      // 更新移动端导航
      document.querySelectorAll('[data-mobile-nav-item]').forEach(link => {
        const href = link.getAttribute('data-href');
        const icon = link.querySelector('[data-icon]');
        
        if (isActive(href, currentPath)) {
          link.classList.add('mobile-nav-link-active');
          if (icon) icon.classList.add('text-indigo-500');
        } else {
          link.classList.remove('mobile-nav-link-active');
          if (icon) icon.classList.remove('text-indigo-500');
        }
      });
    }
    
    // 安全获取事件目标元素（兼容文本节点和 SVG）
    function getEventTarget(e) {
      const target = e.target;
      if (!target) return null;
      if (target.nodeType === Node.TEXT_NODE) return target.parentElement;
      if (typeof target.closest === 'function') return target;
      return null;
    }
    
    // 初始化移动菜单
    function initMobileMenu() {
      // 使用事件委托，避免重复绑定问题
      document.addEventListener('click', (e) => {
        const target = getEventTarget(e);
        if (!target) return;
        const btn = target.closest('#mobile-menu-btn');
        if (!btn) return;
        
        const menu = document.getElementById('mobile-menu');
        if (!menu) return;

        e.preventDefault();
        const menuIcon = btn.querySelector('#menu-icon');
        const closeIcon = btn.querySelector('#close-icon');
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        
        btn.setAttribute('aria-expanded', String(!isExpanded));
        menu.classList.toggle('hidden');
        menuIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
      });
      
      // 点击移动端菜单链接后关闭菜单
      document.addEventListener('click', (e) => {
        const target = getEventTarget(e);
        if (!target) return;
        const link = target.closest('#mobile-menu a');
        if (!link) return;
        
        const menu = document.getElementById('mobile-menu');
        const btn = document.getElementById('mobile-menu-btn');
        if (!menu || !btn) return;

        const menuIcon = btn?.querySelector('#menu-icon');
        const closeIcon = btn?.querySelector('#close-icon');
        
        menu.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        btn?.setAttribute('aria-expanded', 'false');
      });
    }
    
    // 初始化桌面端下拉菜单 - document 事件委托，兼容 View Transitions
    function initDesktopDropdown() {
      let closeTimeout = null;
      
      // 安全获取元素节点（文本节点转父元素）
      function getEl(node) {
        if (!node) return null;
        if (node.nodeType === Node.TEXT_NODE) return node.parentElement;
        if (typeof node.closest === 'function') return node;
        return null;
      }
      
      // 使用事件委托处理所有下拉菜单（mouseenter/mouseleave 不冒泡，用捕获阶段）
      document.addEventListener('mouseenter', (e) => {
        const el = getEl(e.target);
        if (!el) return;
        const wrapper = el.closest('[data-dropdown]');
        if (!wrapper) return;
        
        // 清除关闭定时器
        if (closeTimeout) {
          clearTimeout(closeTimeout);
          closeTimeout = null;
        }
        
        // 关闭其他已打开的下拉菜单
        document.querySelectorAll('[data-dropdown-menu]').forEach(d => {
          if (!wrapper.contains(d)) {
            d.classList.remove('dropdown-visible');
            d.classList.add('dropdown-hidden');
          }
        });
        
        // 打开当前下拉菜单
        const dropdown = wrapper.querySelector('[data-dropdown-menu]');
        if (dropdown) {
          dropdown.classList.remove('dropdown-hidden');
          dropdown.classList.add('dropdown-visible');
        }
      }, true);
      
      document.addEventListener('mouseleave', (e) => {
        const el = getEl(e.target);
        if (!el) return;
        const wrapper = el.closest('[data-dropdown]');
        if (!wrapper) return;
        
        // 如果鼠标只是移动到了 wrapper 内部的另一个元素，不关闭
        const related = getEl(e.relatedTarget);
        if (related && wrapper.contains(related)) return;
        
        const dropdown = wrapper.querySelector('[data-dropdown-menu]');
        if (dropdown) {
          closeTimeout = setTimeout(() => {
            dropdown.classList.remove('dropdown-visible');
            dropdown.classList.add('dropdown-hidden');
          }, 150);
        }
      }, true);
      
      // 点击下拉菜单中的链接后关闭菜单
      document.addEventListener('click', (e) => {
        const target = getEventTarget(e);
        if (!target) return;
        const link = target.closest('[data-dropdown-menu] a');
        if (!link) return;
        
        // 关闭所有下拉菜单
        document.querySelectorAll('[data-dropdown-menu]').forEach(d => {
          d.classList.remove('dropdown-visible');
          d.classList.add('dropdown-hidden');
        });
      });
    }

    // 初始化移动端 Command Palette 触发（使用事件委托）
    function initMobileCmdTrigger() {
      document.addEventListener('click', (e) => {
        const target = getEventTarget(e);
        if (!target) return;
        const mobileTrigger = target.closest('#mobile-cmd-trigger');
        if (!mobileTrigger) return;
        
        const desktopTrigger = document.getElementById('cmd-palette-trigger');
        if (desktopTrigger) {
          desktopTrigger.click();
        }
      });
    }
    
    // ========== 导航栏背景切换 ==========
    let navScrollHandler = null;
    function initNavBackground() {
      const nav = document.getElementById('main-nav');
      const navBg = nav?.querySelector('.nav-bg');
      if (!nav || !navBg) return;
      
      // 清理旧的滚动监听器
      if (navScrollHandler) {
        window.removeEventListener('scroll', navScrollHandler);
        navScrollHandler = null;
      }
      
      // 检测是否在首页 Hero 区域（有动态背景）
      const path = window.location.pathname;
      const isHomePage = path === '/' || path === '/index.html';
      const hasAnimatedBg = document.querySelector('.animated-bg') !== null;
      
      // 使用 CSS 变量方式设置玻璃态样式
      function applyGlassStyle() {
        navBg.style.backgroundColor = 'color-mix(in oklch, var(--background) 80%, transparent)';
        navBg.style.borderBottom = '1px solid color-mix(in oklch, var(--border) 50%, transparent)';
        navBg.style.backdropFilter = 'blur(24px)';
        navBg.style.webkitBackdropFilter = 'blur(24px)';
      }
      
      if (!isHomePage || !hasAnimatedBg) {
        // 非首页或无动态背景，始终显示玻璃态背景
        navBg.style.opacity = '1';
        applyGlassStyle();
        return;
      }
      
      // 首页：根据滚动位置切换背景
      function updateNavBg() {
        const scrollY = window.scrollY || window.pageYOffset;
        const threshold = 80;
        
        if (scrollY > threshold) {
          navBg.style.opacity = '1';
          applyGlassStyle();
        } else {
          const progress = scrollY / threshold;
          const opacity = 0.3 + progress * 0.7;
          navBg.style.opacity = String(opacity);
          navBg.style.backgroundColor = 'color-mix(in oklch, var(--background) 40%, transparent)';
          navBg.style.backdropFilter = 'blur(12px)';
          navBg.style.webkitBackdropFilter = 'blur(12px)';
          navBg.style.borderBottom = '1px solid color-mix(in oklch, var(--border) 30%, transparent)';
        }
      }
      
      // 首页初始状态
      navBg.style.opacity = '0.3';
      navBg.style.backgroundColor = 'color-mix(in oklch, var(--background) 40%, transparent)';
      navBg.style.backdropFilter = 'blur(12px)';
      navBg.style.webkitBackdropFilter = 'blur(12px)';
      navBg.style.borderBottom = '1px solid color-mix(in oklch, var(--border) 30%, transparent)';
      
      updateNavBg();
      
      // 监听滚动
      let ticking = false;
      navScrollHandler = function() {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateNavBg();
            ticking = false;
          });
          ticking = true;
        }
      };
      window.addEventListener('scroll', navScrollHandler, { passive: true });
    }
    
    // 全局主题变化监听（只设置一次）
    (function setupThemeListener() {
      if (window.__navThemeObserver) return;
      
      const nav = document.getElementById('main-nav');
      const navBg = nav?.querySelector('.nav-bg');
      if (!nav || !navBg) return;
      
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            if (navBg.style.opacity === '1') {
              navBg.style.backgroundColor = 'color-mix(in oklch, var(--background) 80%, transparent)';
              navBg.style.borderBottom = '1px solid color-mix(in oklch, var(--border) 50%, transparent)';
            }
          }
        });
      });
      
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
      });
      
      window.__navThemeObserver = true;
    })();
    
    // 初始化（只执行一次的逻辑）
    function initOnce() {
      if (window.__navInitOnce) return;
      window.__navInitOnce = true;
      
      initMobileMenu();
      initMobileCmdTrigger();
      initDesktopDropdown();
    }
    
    // 重置菜单状态
    function resetMenus() {
      // 重置移动菜单
      const menu = document.getElementById('mobile-menu');
      const btn = document.getElementById('mobile-menu-btn');
      if (menu && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        btn?.setAttribute('aria-expanded', 'false');
        btn?.querySelector('#menu-icon')?.classList.remove('hidden');
        btn?.querySelector('#close-icon')?.classList.add('hidden');
      }
      
      // 重置桌面端下拉菜单 - 清除 JS 控制的状态
      document.querySelectorAll('[data-dropdown-menu]').forEach(d => {
        d.classList.remove('dropdown-visible', 'dropdown-hidden');
      });
    }
    
    // 每次页面切换后需要更新的逻辑
    function init() {
      updateNavHighlight();
      initNavBackground();
      resetMenus();
    }
    
    // 首次加载
    initOnce();
    init();
    
    // ClientRouter 页面切换后更新
    document.addEventListener('astro:page-load', init);
    
    // 后退/前进按钮导航时更新高亮
    window.addEventListener('popstate', updateNavHighlight);
  })();
</script>

<style>
  /* 桌面端下拉菜单 - JS 控制 */
  .dropdown-menu {
    pointer-events: none;
  }
  
  .dropdown-menu.dropdown-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  
  .dropdown-menu.dropdown-hidden {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    pointer-events: none;
  }
  
  /* 保留原来的 group-hover 作为降级方案 */
  @media (hover: hover) {
    .group:hover .dropdown-menu:not(.dropdown-visible):not(.dropdown-hidden) {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }
  }
</style>
