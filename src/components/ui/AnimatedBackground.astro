---
/**
 * @component AnimatedBackground
 * @description 首页动态背景组件，提供微妙的渐变网格动画
 * @features 渐变网格、鼠标视差效果、IntersectionObserver 淡出、性能优化（GPU加速）
 * @usage 在首页 Hero Section 使用
 */
---

<div class="animated-bg" aria-hidden="true" id="hero-bg">
  <div class="gradient-base"></div>
  <div class="gradient-mesh" id="gradient-mesh">
    <div class="mesh-blob mesh-1"></div>
    <div class="mesh-blob mesh-2"></div>
    <div class="mesh-blob mesh-3"></div>
    <div class="mesh-blob mesh-4"></div>
  </div>
  <div class="noise-overlay"></div>
  <div class="fade-overlay"></div>
</div>

<script is:inline src="/js/animated-bg.js"></script>

<style>
  .animated-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(99, 102, 241, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(168, 85, 247, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(59, 130, 246, 0.04) 0%, transparent 60%);
    transition: opacity 0.5s ease;
  }

  :global(.dark) .gradient-base {
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(99, 102, 241, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(168, 85, 247, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(59, 130, 246, 0.06) 0%, transparent 60%);
  }

  .gradient-mesh {
    position: absolute;
    inset: -50%;
    width: 200%;
    height: 200%;
    animation: mesh-rotate 60s linear infinite;
    transform: translate(var(--parallax-x, 0), var(--parallax-y, 0));
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: blob-float 20s ease-in-out infinite;
  }

  .mesh-1 { width: 600px; height: 600px; top: 20%; left: 15%; background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(168, 85, 247, 0.2)); animation-delay: 0s; animation-duration: 25s; }
  .mesh-2 { width: 500px; height: 500px; top: 50%; left: 60%; background: linear-gradient(135deg, rgba(236, 72, 153, 0.25), rgba(168, 85, 247, 0.15)); animation-delay: -5s; animation-duration: 30s; }
  .mesh-3 { width: 400px; height: 400px; top: 40%; left: 40%; background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(99, 102, 241, 0.1)); animation-delay: -10s; animation-duration: 22s; }
  .mesh-4 { width: 350px; height: 350px; top: 15%; left: 70%; background: linear-gradient(135deg, rgba(14, 165, 233, 0.25), rgba(59, 130, 246, 0.15)); animation-delay: -15s; animation-duration: 28s; }

  :global(.dark) .mesh-blob { opacity: 0.25; filter: blur(100px); animation-name: blob-float-dark; }

  .noise-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  :global(.dark) .noise-overlay { opacity: 0.04; }

  .fade-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to bottom, transparent 0%, var(--background) 100%);
    pointer-events: none;
    z-index: 1;
  }

  @keyframes mesh-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes blob-float {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    25% { transform: translate(30px, -30px) scale(1.05); opacity: 0.35; }
    50% { transform: translate(-20px, 20px) scale(0.95); opacity: 0.45; }
    75% { transform: translate(20px, 30px) scale(1.02); opacity: 0.3; }
  }

  @keyframes blob-float-dark {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.25; }
    25% { transform: translate(30px, -30px) scale(1.05); opacity: 0.2; }
    50% { transform: translate(-20px, 20px) scale(0.95); opacity: 0.3; }
    75% { transform: translate(20px, 30px) scale(1.02); opacity: 0.18; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gradient-mesh, .mesh-blob { animation: none; }
  }

  @media (max-width: 768px) {
    .mesh-blob { filter: blur(60px); opacity: 0.3; }
    .mesh-1 { width: 300px; height: 300px; }
    .mesh-2 { width: 250px; height: 250px; }
    .mesh-3 { width: 200px; height: 200px; }
    .mesh-4 { display: none; }
  }
</style>
